# Server Configuration
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=iot
DB_PORT=3306

# MQTT Configuration
# For HiveMQ Cloud use: mqtts://<host>:8883
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_BROKER=
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=
MQTT_TLS_REJECT_UNAUTHORIZED=true

# ESP32 topics
MQTT_TOPIC_DEVICE_DATA=iot/device/+/data
MQTT_TOPIC_DEVICE_COMMAND=iot/device/{deviceId}/command
MQTT_TOPIC_DEVICE_STATUS=

# Legacy topics (optional)
MQTT_TOPIC_SENSOR=sensor/data
MQTT_TOPIC_DEVICE=device/control

# Sensor IDs (Dashboard)
SENSOR_TEMPERATURE_ID=your-temperature-sensor-id
SENSOR_HUMIDITY_ID=your-humidity-sensor-id
SENSOR_LIGHT_ID=your-light-sensor-id
SENSOR_DUST_ID=your-dust-sensor-id
