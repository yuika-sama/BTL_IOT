# Server Configuration
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=iot
DB_PORT=3306

# MQTT Configuration
MQTT_BROKER=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_SENSOR=sensor/data
MQTT_TOPIC_DEVICE=device/control

# Sensor IDs (Dashboard)
SENSOR_TEMPERATURE_ID=your-temperature-sensor-id
SENSOR_HUMIDITY_ID=your-humidity-sensor-id
SENSOR_LIGHT_ID=your-light-sensor-id
SENSOR_DUST_ID=your-dust-sensor-id
